* text=auto

.gitattributes text eol=lf
.gitignore text eol=lf
.dockerignore text eol=lf
go.mod text eol=lf
go.sum text eol=lf
*.sh text eol=lf
Makefile text eol=lf
Dockerfile* text eol=lf
*.go text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.jsonl text eol=lf
*.md text eol=lf

# Formal source archives must not export consumed evaluation, holdout, blind,
# private, or retired material. The release packager repeats these exclusions
# explicitly and verifies the resulting archive fail-closed.
/cmd/evaluation-* export-ignore
/cmd/holdout-* export-ignore
/cmd/*private* export-ignore
/cmd/*blind* export-ignore
/cmd/*retired* export-ignore
/docs/reports/EVALUATION_* export-ignore
/docs/reports/HOLDOUT_* export-ignore
/docs/reports/HOLDOUT_REPORT.md export-ignore
/docs/**/*private* export-ignore
/docs/**/*blind* export-ignore
/docs/**/*retired* export-ignore
/internal/classifier/evaluation_* export-ignore
/internal/classifier/holdout_* export-ignore
/internal/classifier/*private* export-ignore
/internal/classifier/*blind* export-ignore
/internal/classifier/*retired* export-ignore
/testdata/evaluation-* export-ignore
/testdata/holdout* export-ignore
/testdata/*private* export-ignore
/testdata/*blind* export-ignore
/testdata/*retired* export-ignore
/scripts/verify-frozen-evaluation-v10-tree.sh export-ignore
