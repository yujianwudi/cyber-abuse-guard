FROM golang:1.26-bookworm

RUN apt-get update \
    && apt-get install -y --no-install-recommends build-essential ca-certificates git make file zip unzip \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .

ENV CGO_ENABLED=1
CMD ["bash", "-euc", "make test vet race fuzz-smoke build-linux-amd64 integration-test"]
